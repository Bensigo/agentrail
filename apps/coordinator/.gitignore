# Dependencies
node_modules/

# Eve build + dev runtime artifacts (ephemeral — regenerated by `eve dev`/`eve build`)
.eve/
.output/

# Eve local durable run store (graphile-worker/world-local writes hundreds of
# per-run lock/event/step files here). Never commit — it's per-machine state.
.workflow-data/

# Local env / secrets — NEVER commit. Eve reads AI_GATEWAY_API_KEY /
# VERCEL_OIDC_TOKEN / ANTHROPIC_API_KEY from here.
.env
.env.*
!.env.example

# Logs / tmp
*.log
