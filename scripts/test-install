#!/usr/bin/env bash
set -euo pipefail

tmp_dir="$(mktemp -d)"
cleanup() {
  rm -rf "$tmp_dir"
}
trap cleanup EXIT

installer="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/install-workflow"

"$installer" --target "$tmp_dir"

if "$installer" --target --force >"${tmp_dir}/missing-target.out" 2>&1; then
  echo "--target accepted another option as its directory argument" >&2
  exit 1
fi

if ! grep -q -- "--target requires a directory" "${tmp_dir}/missing-target.out"; then
  echo "--target missing-argument error was not reported" >&2
  exit 1
fi

required=(
  ".codex/agents/github-pr-reviewer.md"
  ".claude/agents/github-pr-reviewer.md"
  "AGENTS.md"
  "CONTEXT.md"
  "docs/agents/issue-tracker.md"
  "docs/agents/milestones.md"
  "docs/agents/ralph-loop.md"
  "docs/agents/pr-review.md"
  "docs/agents/github-pr-reviewer.md"
  "docs/agents/visual-evidence.md"
  "docs/agents/triage-labels.md"
  "docs/memory/README.md"
  "docs/memory/decisions.md"
  "docs/memory/lessons.md"
  "docs/memory/failure-patterns.md"
  "docs/memory/project-preferences.md"
  "docs/prd/.gitkeep"
  "docs/milestones/.gitkeep"
  "scripts/memory"
  "scripts/afk-workflow"
  "scripts/pr"
  "scripts/ralph-loop"
  "scripts/review-pr"
  "skills/ai-workflow/SKILL.md"
  "skills/grill-with-docs/SKILL.md"
  "skills/grill-with-docs/ADR-FORMAT.md"
  "skills/grill-with-docs/CONTEXT-FORMAT.md"
  "skills/to-prd/SKILL.md"
  "skills/to-milestones/SKILL.md"
  "skills/to-milestones/agents/openai.yaml"
  "skills/to-issues/SKILL.md"
  "skills/tdd/SKILL.md"
  "skills/tdd/deep-modules.md"
  "skills/tdd/interface-design.md"
  "skills/tdd/mocking.md"
  "skills/tdd/refactoring.md"
  "skills/tdd/tests.md"
  "skills/visual-evidence-for-prs/SKILL.md"
)

for file in "${required[@]}"; do
  if [[ ! -e "${tmp_dir}/${file}" ]]; then
    echo "missing installed file: ${file}" >&2
    exit 1
  fi
done

for script in memory ralph-loop afk-workflow review-pr pr; do
  if [[ ! -x "${tmp_dir}/scripts/${script}" ]]; then
    echo "installed script is not executable: scripts/${script}" >&2
    exit 1
  fi
done

for skill in grill-with-docs to-prd to-milestones to-issues tdd visual-evidence-for-prs; do
  if ! grep -q -- "$skill" "${tmp_dir}/AGENTS.md"; then
    echo "AGENTS.md does not mention required skill: ${skill}" >&2
    exit 1
  fi
done

if grep -Rqi -- "bensigo" "${tmp_dir}/skills"; then
  echo "installed skills contain project-owner branding" >&2
  exit 1
fi

if ! grep -q -- "No visual surface" "${tmp_dir}/skills/visual-evidence-for-prs/SKILL.md"; then
  echo "visual-evidence-for-prs skill does not include a non-visual fallback" >&2
  exit 1
fi

if ! grep -q -- "Acceptance Criteria Coverage" "${tmp_dir}/docs/agents/ralph-loop.md"; then
  echo "ralph-loop docs do not require acceptance criteria coverage" >&2
  exit 1
fi

if ! grep -q -- "Acceptance Criteria Coverage" "${tmp_dir}/docs/agents/pr-review.md"; then
  echo "pr-review docs do not require acceptance criteria coverage checks" >&2
  exit 1
fi

if ! grep -q -- '"repo": "owner/name"' "${tmp_dir}/docs/agents/github-pr-reviewer.md"; then
  echo "github-pr-reviewer docs do not define repo input" >&2
  exit 1
fi

if ! grep -q -- "name: github-pr-reviewer" "${tmp_dir}/.claude/agents/github-pr-reviewer.md"; then
  echo "github-pr-reviewer custom subagent does not define its name" >&2
  exit 1
fi

if ! grep -q -- "name: github-pr-reviewer" "${tmp_dir}/.codex/agents/github-pr-reviewer.md"; then
  echo "github-pr-reviewer Codex subagent adapter does not define its name" >&2
  exit 1
fi

if ! grep -q -- '"pr_number": 123' "${tmp_dir}/docs/agents/github-pr-reviewer.md"; then
  echo "github-pr-reviewer docs do not define PR number input" >&2
  exit 1
fi

if ! grep -q -- '"fix_issues": \[\]' "${tmp_dir}/docs/agents/github-pr-reviewer.md"; then
  echo "github-pr-reviewer docs do not define fix_issues output" >&2
  exit 1
fi

if grep -q -- '"fix_issue": null' "${tmp_dir}/docs/agents/github-pr-reviewer.md"; then
  echo "github-pr-reviewer docs still use singular fix_issue output" >&2
  exit 1
fi

if ! grep -q -- '"memory_suggestions": \[\]' "${tmp_dir}/docs/agents/github-pr-reviewer.md"; then
  echo "github-pr-reviewer docs do not define memory_suggestions output" >&2
  exit 1
fi

if ! grep -q -- "Memory Pattern Check" "${tmp_dir}/docs/agents/pr-review.md"; then
  echo "pr-review docs do not require memory pattern classification" >&2
  exit 1
fi

if ! grep -q -- "memory-suggestion" "${tmp_dir}/scripts/afk-workflow"; then
  echo "afk-workflow does not handle memory-suggestion issues" >&2
  exit 1
fi

if ! grep -q -- "must not:" "${tmp_dir}/docs/agents/github-pr-reviewer.md"; then
  echo "github-pr-reviewer docs do not state review bounds" >&2
  exit 1
fi

if ! grep -q -- "docs/agents/pr-review.md" "${tmp_dir}/scripts/review-pr"; then
  echo "review-pr script does not load installed PR review instructions" >&2
  exit 1
fi

if grep -q -- "review/prompt.md" "${tmp_dir}/scripts/review-pr"; then
  echo "review-pr script still depends on missing review/prompt.md" >&2
  exit 1
fi

if ! grep -q -- "AC1" "${tmp_dir}/skills/to-issues/SKILL.md"; then
  echo "to-issues skill does not require labeled acceptance criteria" >&2
  exit 1
fi

if ! grep -q -- "## Verification evidence" "${tmp_dir}/skills/to-issues/SKILL.md"; then
  echo "to-issues skill does not separate verification evidence from acceptance criteria" >&2
  exit 1
fi

if grep -q -- "AC3: <Required verification evidence" "${tmp_dir}/skills/to-issues/SKILL.md"; then
  echo "to-issues skill still models verification evidence as an acceptance criterion" >&2
  exit 1
fi

if ! grep -q -- "scripts/memory recall" "${tmp_dir}/AGENTS.md"; then
  echo "AGENTS.md does not tell agents to recall project memory" >&2
  exit 1
fi

if ! grep -q -- "scripts/memory recall" "${tmp_dir}/docs/agents/ralph-loop.md"; then
  echo "ralph-loop docs do not require project memory recall" >&2
  exit 1
fi

if ! grep -q -- "source:" "${tmp_dir}/docs/memory/README.md"; then
  echo "memory README does not require source-linked entries" >&2
  exit 1
fi

(
  cd "$tmp_dir"
  cat >> docs/memory/decisions.md <<'MEMORY'

## Prefer server-side validation

- kind: decision
- source: docs/adr/0001-validation.md
- confidence: verified

Keep validation rules server-side when they affect persisted business state.
MEMORY

  if ! scripts/memory recall "validation" | grep -q -- "Prefer server-side validation"; then
    echo "memory recall did not find relevant installed memory" >&2
    exit 1
  fi

  if ! scripts/memory recall "persisted validation" | grep -q -- "Prefer server-side validation"; then
    echo "memory recall did not handle multiple non-adjacent query terms" >&2
    exit 1
  fi

  cat >> docs/memory/lessons.md <<'MEMORY'

## [codex] Bracketed PR titles stay literal

- kind: lesson
- source: PR #4
- confidence: verified

Recall queries should treat bracketed PR title prefixes as literal text.
MEMORY

  no_rg_bin="${tmp_dir}/no-rg-bin"
  mkdir -p "$no_rg_bin"
  for binary in bash git grep; do
    ln -s "$(command -v "$binary")" "${no_rg_bin}/${binary}"
  done

  PATH="$no_rg_bin" scripts/memory recall "[codex]" > "${tmp_dir}/bracketed-recall.out"

  if ! grep -q -- "Bracketed PR titles stay literal" "${tmp_dir}/bracketed-recall.out"; then
    echo "memory recall grep fallback did not find a bracketed literal query" >&2
    exit 1
  fi

  if grep -q -- "# Project Memory" "${tmp_dir}/bracketed-recall.out"; then
    echo "memory recall grep fallback treated bracketed query as a regex" >&2
    exit 1
  fi
)

echo "install test passed"
