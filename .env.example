# Postgres
DATABASE_URL=postgresql://agentrail:agentrail@localhost:5432/agentrail

# ClickHouse
CLICKHOUSE_URL=http://agentrail:agentrail@localhost:8123/agentrail

# MinIO / S3-compatible object storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=agentrail
S3_SECRET_KEY=agentrail123
S3_BUCKET=agentrail-artifacts

# Auth.js (generate with: openssl rand -hex 32)
AUTH_SECRET=your-auth-secret-here

# GitHub OAuth (register at https://github.com/settings/developers)
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# AFK pipeline / server link
# These three vars are injected by the afk runner into each worktree so that
# snapshot_push.py can reach the dashboard ingest endpoints when no
# .agentrail/server.json is present (e.g. inside an afk worktree).
AGENTRAIL_SERVER_BASE_URL=http://localhost:3000   # base URL of the AgentRail server
AGENTRAIL_SERVER_API_KEY=your-api-key-here        # API key for authenticating with the server
AGENTRAIL_SERVER_REPOSITORY_ID=your-repo-id-here  # repository ID the run is associated with
