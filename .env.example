# Postgres
DATABASE_URL=postgresql://agentrail:agentrail@localhost:5432/agentrail

# ClickHouse
CLICKHOUSE_URL=http://agentrail:agentrail@localhost:8123/agentrail

# MinIO / S3-compatible object storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=agentrail
S3_SECRET_KEY=agentrail123
S3_BUCKET=agentrail-artifacts

# Auth.js (generate with: openssl rand -hex 32)
AUTH_SECRET=your-auth-secret-here

# Jace GitHub App (register at https://github.com/settings/apps — see the
# deploy example for the full registration checklist). ONE App serves both
# console login (client id/secret below) and repo access (App id + private
# key, read by @agentrail/github-app).
# Login callback URL on the App: http://localhost:3000/api/auth/callback/github
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Full PEM contents of the App's private key (literal \n newlines are OK).
GITHUB_APP_PRIVATE_KEY=
# Numeric user id of <slug>[bot] — curl https://api.github.com/users/<slug>%5Bbot%5D | jq .id
GITHUB_APP_BOT_USER_ID=

# AFK pipeline / server link
# These three vars are injected by the afk runner into each worktree so that
# snapshot_push.py can reach the dashboard ingest endpoints when no
# .agentrail/server.json is present (e.g. inside an afk worktree).
AGENTRAIL_SERVER_BASE_URL=http://localhost:3000   # base URL of the AgentRail server
AGENTRAIL_SERVER_API_KEY=your-api-key-here        # API key for authenticating with the server
AGENTRAIL_SERVER_REPOSITORY_ID=your-repo-id-here  # repository ID the run is associated with

# Input-Contract v2 queue-entrance guardrails (#1022 / #1026 / #1034)
# Turns ON the queue-admission guardrails at BOTH entrances — the Python queue
# store (heartbeat `run`/`serve`) and the TS webhook (`enqueueGithubIssue`):
# prompt-injection screening, duplicate-content dedup, and per-writer rate limits.
# The code default is OFF (rollout safety); set this to "1" to enable it per
# environment (reversible — unset or "0" restores the legacy path byte-for-byte).
# Safe to enable: an injection/dup/rate-limit hit PARKS a durable, human-reviewable
# queue row — it never DROPS a legitimate issue on the live path. Note: the
# rate-limit ledger is per long-lived process (no time-window reset yet), so a
# very high-volume writer can accumulate parks over a long daemon uptime; those are
# recoverable (unpark), not lost. Validate before flipping in prod with:
#   PYTHONPATH=$(pwd) python3 agentrail/scripts/validate-input-contract-v2.py
AGENTRAIL_QUEUE_GUARDRAILS_V2=1
