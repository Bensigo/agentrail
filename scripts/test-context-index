# Memory
DOC
cat >"${source_fixture}/templates/docs/prd/README.md" <<'DOC'
# PRD
DOC
cat >"${source_fixture}/templates/docs/milestones/README.md" <<'DOC'
# Milestones
DOC
cat >"${source_fixture}/templates/scripts/afk-workflow" <<'SH'
