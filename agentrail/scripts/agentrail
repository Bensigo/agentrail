#!/usr/bin/env bash
set -euo pipefail

source_path="${BASH_SOURCE[0]}"
while [[ -L "$source_path" ]]; do
  source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
  linked_path="$(readlink "$source_path")"
  if [[ "$linked_path" == /* ]]; then
    source_path="$linked_path"
  else
    source_path="${source_dir}/${linked_path}"
  fi
done

script_dir="$(cd -P "$(dirname "$source_path")" && pwd)"

# #404 Option B: in an installed project, the editable flow scripts are gone but
# the native package is vendored under .agentrail/source. Resolve the package via
# the vendored package.json redirect (kept working by the installer).
#
# This launcher lives at two different depths depending on where it runs from:
#   - installed copy: <target_dir>/scripts/agentrail          (1 level below the target project root)
#   - native in-repo:  <repo_root>/agentrail/scripts/agentrail (2 levels below the repo root)
# Try the 1-level-up candidate first (the installed-copy contract), and only
# fall back to the 2-level-up candidate (native in-repo layout) if the first
# doesn't resolve to anything importable/vendored (#1136).
resolve_repo_dir() {
  local candidate="$1"
  if [[ -f "${candidate}/.agentrail/source/package.json" && -f "${candidate}/.agentrail/source/agentrail/__init__.py" ]]; then
    echo "${candidate}/.agentrail/source"
    return 0
  fi
  if [[ -f "${candidate}/agentrail/__init__.py" ]]; then
    echo "$candidate"
    return 0
  fi
  return 1
}

one_up="$(cd "${script_dir}/.." && pwd)"
two_up="$(cd "${script_dir}/../.." && pwd)"

if resolved_dir="$(resolve_repo_dir "$one_up")"; then
  repo_dir="$resolved_dir"
elif resolved_dir="$(resolve_repo_dir "$two_up")"; then
  repo_dir="$resolved_dir"
else
  # Neither candidate resolved to an importable/vendored package. Default to
  # the native in-repo layout depth so the import-verification fallback chain
  # below still has a sane candidate to test against.
  repo_dir="$two_up"
fi

pick_python() {
  if command -v python3 >/dev/null 2>&1; then
    echo python3
  elif [[ -x /usr/bin/python3 ]]; then
    echo /usr/bin/python3
  else
    echo python
  fi
}
python_bin="$(pick_python)"

# Verify the resolved package actually imports; otherwise fall back to an
# `agentrail` already on PATH (e.g. a globally installed CLI).
if PYTHONPATH="${repo_dir}${PYTHONPATH:+:${PYTHONPATH}}" "$python_bin" -c 'import agentrail.cli.main' >/dev/null 2>&1; then
  export PYTHONPATH="${repo_dir}${PYTHONPATH:+:${PYTHONPATH}}"
  exec "$python_bin" -m agentrail.cli.main "$@"
elif command -v agentrail >/dev/null 2>&1 && [[ "$(command -v agentrail)" != "$source_path" ]]; then
  exec agentrail "$@"
else
  export PYTHONPATH="${repo_dir}${PYTHONPATH:+:${PYTHONPATH}}"
  exec "$python_bin" -m agentrail.cli.main "$@"
fi
