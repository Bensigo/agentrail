# AgentRail production env — copy to deploy/.env and fill in every REQUIRED
# value before `docker compose -f deploy/docker-compose.prod.yml up -d --build`.
# Referenced by docker-compose.prod.yml's `env_file: ./.env` on every service
# (each service only reads the vars it actually uses; harmless overlap).
#
#   cp deploy/.env.production.example deploy/.env
#
# Every var below was confirmed by reading the actual source that consumes it
# (see the comment above each) — nothing here is guessed. Full setup steps for
# each "you must supply" credential are in deploy/README.md.

# =============================================================================
# Postgres — shared by console (DATABASE_URL) and Jace (WORKFLOW_POSTGRES_URL,
# derived from DATABASE_URL in docker-compose.prod.yml). ONE instance, ONE
# database, for this single-tenant deploy.
# =============================================================================

# REQUIRED. Any strong random string — this becomes the postgres superuser
# password for the `postgres` compose service AND must match the password
# baked into DATABASE_URL below (generate: openssl rand -hex 24).
POSTGRES_PASSWORD=

# Optional — defaults baked into docker-compose.prod.yml if unset.
POSTGRES_USER=agentrail
POSTGRES_DB=agentrail

# REQUIRED. Must use the `postgres` service hostname (compose's internal DNS),
# port 5432, and match POSTGRES_USER/PASSWORD/DB above exactly. Consumed by
# packages/db-postgres/src/migrate.ts (migrations), packages/auth/src/index.ts
# (session store), and re-used by Jace as WORKFLOW_POSTGRES_URL (see
# docker-compose.prod.yml's `jace` service — Eve's @workflow/world-postgres
# state adapter, a DIFFERENT env-var name than this one, verified against that
# package's own README).
DATABASE_URL=postgresql://agentrail:CHANGE_ME@postgres:5432/agentrail

# =============================================================================
# Console (apps/console) — Next.js dashboard + API. Node 24, standalone build.
# =============================================================================

# REQUIRED. Auth.js (next-auth v5) session/JWT signing secret.
# Generate: openssl rand -hex 32
AUTH_SECRET=

# REQUIRED. GitHub OAuth App credentials — YOU MUST SUPPLY THESE. Register at
# https://github.com/settings/developers -> "New OAuth App":
#   Homepage URL:            https://65.20.91.127.sslip.io
#   Authorization callback:  https://65.20.91.127.sslip.io/api/auth/callback/github
# (packages/auth/src/index.ts requests the `repo` scope on login so the stored
# access_token can also drive the GitHub connector — see GITHUB_OAUTH_TOKEN
# below, which is that SAME token surfaced to Jace, not a second app.)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# REQUIRED. Encrypts connector secrets (e.g. connector API keys) at rest in
# Postgres (packages/db-postgres/src/crypto.ts, AES-256-GCM). Deliberately
# NOT derived from AUTH_SECRET — different rotation lifecycle. 32+ random
# chars. Generate: openssl rand -hex 32
CONNECTOR_SECRET_KEY=

# Optional but recommended. HMAC-signs the GitHub `issues` webhook
# (apps/console/app/api/v1/connectors/github/webhook/route.ts). Unset =
# signature check is SKIPPED (any POST to the webhook URL is trusted) — set
# this to whatever secret you configure on the repo's webhook (see
# deploy/README.md's GitHub setup step).
GITHUB_WEBHOOK_SECRET=

# Optional. ClickHouse is NOT deployed in this compose file (see
# docker-compose.prod.yml's header comment) — leave unset. Every write path
# that uses it is try/caught (verified: apps/console/app/api/v1/runner/result/route.ts
# swallows ClickHouse insert failures and still returns 202). One exception:
# POST /api/v1/ingest/cost-events returns HTTP 502 if ClickHouse is
# unreachable rather than degrading — a non-critical ancillary ingest path,
# not on the runner's claim/execute/report loop. Leave CLICKHOUSE_URL unset
# unless you stand up ClickHouse yourself.
# CLICKHOUSE_URL=
# CLICKHOUSE_USER=
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DB=

# Optional. S3/MinIO — grepped apps/console and every packages/* directory:
# ZERO code reads S3_ENDPOINT/S3_ACCESS_KEY/S3_SECRET_KEY/S3_BUCKET today.
# This is reserved config for a future artifact-storage feature, not live
# code. Leave unset; MinIO is intentionally not in this compose file.
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# Optional. Turns on queue-admission guardrails (prompt-injection screening,
# dedup, per-writer rate limits) at both the Python queue store and the TS
# GitHub-issue webhook. Code default is OFF; "1" enables. See .env.example at
# the repo root for the full rationale. Safe to enable.
# AGENTRAIL_QUEUE_GUARDRAILS_V2=1

# Not set here — pinned directly in docker-compose.prod.yml's `console`
# service because both values are compose-topology-specific, not secrets:
#   EVE_HOST=http://jace:2000        (console -> Jace, internal service DNS)
#   AUTH_TRUST_HOST=true             (required behind Caddy's reverse proxy;
#                                      confirmed via next-auth v5's own deploy
#                                      docs — AUTH_URL itself is NOT needed)

# =============================================================================
# Jace (apps/jace) — Eve/Nitro coordinator sidecar. Node >=24.
# =============================================================================

# REQUIRED for OpenRouter routing (apps/jace/agent/lib/model.core.mjs's
# chooseModel(): setting JACE_MODEL_BASE_URL switches Jace off the Vercel AI
# Gateway path onto any OpenAI-compatible endpoint). Fixed value for
# OpenRouter — do not change.
JACE_MODEL_BASE_URL=https://openrouter.ai/api/v1

# REQUIRED. Your OpenRouter API key (https://openrouter.ai/keys) — YOU MUST
# SUPPLY THIS. Sent as the bearer token to JACE_MODEL_BASE_URL.
JACE_MODEL_API_KEY=

# Optional. OpenRouter model slug (no "openrouter/" prefix — Jace's
# @ai-sdk/openai-compatible client hits JACE_MODEL_BASE_URL directly with this
# as the model id). Default below matches this deploy's runner default
# (RUNNER_MODEL) for consistency; any OpenRouter-listed chat-capable model
# works.
JACE_MODEL_ID=z-ai/glm-4.6

# Optional. Eve refuses to boot on the OpenAI-compatible path without a
# context-window size (no AI Gateway catalog entry to resolve it from — see
# apps/jace/agent/lib/model.core.mjs). Default 8192 is Ollama-sized and almost
# certainly too small for a real OpenRouter model — set it to your chosen
# model's actual context window (check the model's OpenRouter listing).
JACE_MODEL_CONTEXT_WINDOW_TOKENS=131072

# REQUIRED (one of these two). The GitHub OAuth access_token Jace's ONE write
# action (`create_issue` -> `agentrail issue create --connector github`) uses
# — a personal access token with `repo` scope works too. Preferred name read
# first, GITHUB_TOKEN as fallback (agentrail/cli/commands/issue.py). This is
# ALSO what the runner service uses for its own git/gh auth below — one token,
# reused, unless you want to scope them separately.
GITHUB_OAUTH_TOKEN=
GITHUB_TOKEN=

# REQUIRED. Default owner/repo Jace files created issues into
# (agent/lib/create_issue.core.mjs falls back to this when the tool call
# doesn't pass one explicitly). e.g. "your-org/agentrail".
JACE_TARGET_REPO=

# --- Telegram channel — set these three if you want Jace reachable over
# Telegram (deploy/README.md has the BotFather + setWebhook steps). Optional:
# leave all three unset to skip Telegram entirely.
# Also read by the console itself now (issue #1262 PR ②,
# apps/console/lib/telegram-system-message.ts) for its own system sends (the
# multi-workspace "which workspace is this about?" ask + pin confirmation) —
# same shared hosted bot as the sidecar, one token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Also verified by the shared hosted-bot webhook door (issue #1262,
# apps/console/app/api/v1/connectors/telegram/webhook/route.ts) — one bot, one secret.
TELEGRAM_WEBHOOK_SECRET_TOKEN=
# Optional. Hosted deploys set this (shared bot's @username, no @) so the
# setup wizard shows the deep-link flow instead of a token field; self-hosters
# leave it unset to keep the bring-your-own-bot wizard (issue #1262 PR ③).
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# --- Discord channel — optional, all three or none.
# DISCORD_PUBLIC_KEY=
# DISCORD_APPLICATION_ID=
# DISCORD_BOT_TOKEN=

# --- Slack channel — optional, both or neither.
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# --- iMessage channel (LoopMessage) — optional.
# LOOPMESSAGE_API_KEY=
# LOOPMESSAGE_SENDER_NAME=
# LOOPMESSAGE_WEBHOOK_SECRET_TOKEN=
# LOOPMESSAGE_DEFAULT_RECIPIENT=

# Optional. Langfuse Cloud (https://cloud.langfuse.com) — trace/session
# observability for Jace's turns. YOU MUST SUPPLY THESE if you want tracing;
# omit all three to run without it (apps/jace/agent/instrumentation.ts checks
# isLangfuseConfigured() and no-ops otherwise).
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Optional. Lets Jace's fetch_run_evidence / fetch_workspace_memory tools call
# back into the console's API (workspace memory + failure evidence). Needs a
# console-issued API key, which requires a workspace to already exist — set
# these up AFTER first login/workspace creation, not on first boot.
JACE_CONSOLE_BASE_URL=http://console:3000
JACE_CONSOLE_TOKEN=

# Optional — researcher/qa subagent MCP sidecars. NOT deployed in this compose
# file (see docker-compose.prod.yml's header comment); both subagents degrade
# gracefully when these are unreachable, so leave unset unless you add the
# sidecar services back yourself.
# JACE_PLAYWRIGHT_MCP_URL=
# JACE_AGENT_BROWSER_MCP_URL=
# JACE_BROWSER_USE_MCP_URL=
# BROWSER_USE_LLM_KEY=
# CONTEXT7_API_KEY=

# =============================================================================
# Runner (deploy/runner/) — the headless coding agent that claims queued
# issues and executes them via OpenRouter. See deploy/runner/Dockerfile's
# header comment for the execution-mode + agent-CLI decisions.
# =============================================================================

# REQUIRED. Your OpenRouter API key — can be the SAME key as JACE_MODEL_API_KEY
# above (same provider) or a separate one if you want separate billing/limits.
OPENROUTER_API_KEY=

# Optional. OpenRouter model slug WITHOUT the "openrouter/" prefix (the
# aider-stdin-wrapper adds it) — this is the model the coding agent itself
# uses to write code, a SEPARATE concern from Jace's conversational model
# above (JACE_MODEL_ID), though it defaults to the same slug for consistency.
# Pick something with strong agentic coding results; verify current
# OpenRouter pricing/availability before relying on a specific slug.
RUNNER_MODEL=z-ai/glm-4.6

# NOT listed here on purpose: ANTHROPIC_API_KEY. Do not set it for the runner
# service — its mere presence flips agentrail's sandbox-selection logic into
# Docker-sandbox mode, which this deploy does not provision (no
# /var/run/docker.sock mount). See deploy/runner/Dockerfile.
