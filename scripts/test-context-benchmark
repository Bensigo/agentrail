#!/usr/bin/env bash
set -euo pipefail

tmp_dir="$(mktemp -d)"
cleanup() { rm -rf "$tmp_dir"; }
trap cleanup EXIT

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
agentrail="${repo_dir}/scripts/agentrail"

fixture="${tmp_dir}/repo"
mkdir -p "${fixture}/.agentrail" "${fixture}/src"
git -C "$fixture" init --quiet

cat >"${fixture}/.agentrail/config.json" <<'JSON'
{
  "schemaVersion": 1,
  "context": {
    "includeGlobs": ["**/*"],
    "excludeGlobs": [".git/**", ".agentrail/context/**", ".env", "benchmark-fixtures.json"],
    "maxFileSizeBytes": 262144,
    "skipBinary": true,
    "respectGitIgnore": true,
    "secretRedaction": {"enabled": true, "action": "exclude", "denyGlobs": [".env"]},
    "embedding": {"mode": "disabled", "provider": null, "model": null},
    "summary": {"mode": "disabled", "provider": null, "model": null}
  }
}
JSON

{
  echo "def reconcile_ledger_entries():"
  for n in $(seq 1 80); do echo "    step_${n} = post_entry(${n})"; done
  echo "    return reconcile_ledger_entries"
} >"${fixture}/src/ledger.py"
printf 'def unrelated_helper():\n    return 0\n' >"${fixture}/src/unrelated.py"
printf 'SECRET=must-not-appear\n' >"${fixture}/.env"

cat >"${fixture}/benchmark-fixtures.json" <<'JSON'
{
  "schemaVersion": 1,
  "fixtures": [
    {
      "name": "reconcile-ledger",
      "task": "reconcile_ledger_entries()",
      "requiredSources": ["src/ledger.py"],
      "expectedExcludedSources": [".env"]
    }
  ]
}
JSON

"$agentrail" context benchmark benchmark-fixtures.json --target "$fixture" --json >"${tmp_dir}/benchmark.json"

node - "${tmp_dir}/benchmark.json" <<'NODE'
const fs = require("fs");
const report = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const expected = ["search_full_file_baseline","current","compact_exact","exact_only","semantic_only","always_hybrid","planner_hybrid"];
for (const name of expected) {
  if (!report.variants[name]) { console.error(`missing variant: ${name}`); process.exit(1); }
}
const planner = report.variants.planner_hybrid.metrics;
const current = report.variants.current.metrics;
const baseline = report.variants.search_full_file_baseline.metrics;
const required = ["requiredSourceInclusion","recallAt5","recallAt10","precisionAtBudget","fullFileReadTokens","selectedContextTokens","wastedContextTokens","omittedRequiredSources","staleSourceLeakage","deniedSourceLeakage","staleEmbeddingLeakage","latencyMs","providerCalls"];
for (const key of required) {
  if (!(key in planner)) { console.error(`planner_hybrid missing metric: ${key}`); process.exit(1); }
}
if (planner.requiredSourceInclusion !== 1) { console.error(`required-source inclusion not complete: ${planner.requiredSourceInclusion}`); process.exit(1); }
if (planner.deniedSourceLeakage !== 0 || planner.staleSourceLeakage !== 0 || planner.staleEmbeddingLeakage !== 0) { console.error(`leakage detected: ${JSON.stringify(planner)}`); process.exit(1); }
if (!(planner.selectedContextTokens < current.selectedContextTokens)) { console.error(`planner_hybrid not fewer tokens than current: ${planner.selectedContextTokens} vs ${current.selectedContextTokens}`); process.exit(1); }
if (!(planner.selectedContextTokens < baseline.selectedContextTokens)) { console.error(`planner_hybrid not fewer tokens than full-file baseline: ${planner.selectedContextTokens} vs ${baseline.selectedContextTokens}`); process.exit(1); }
if (!report.passed) { console.error(`benchmark pass gates failed: ${JSON.stringify(report.passGates)}`); process.exit(1); }
NODE

echo "context benchmark test passed"
